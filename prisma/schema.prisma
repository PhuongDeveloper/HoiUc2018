generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique @db.VarChar(255)
  password    String   @db.VarChar(255)
  balance     Int      @default(0)
  luong       Int      @default(0)
  level       String   @default("member") @db.VarChar(50)
  banned      String   @default("OFF") @db.VarChar(10)
  activated   Int      @default(1)
  kichhoat    Int      @default(0)
  total_money Int      @default(0)
  tongnap     Int      @default(0)
  tokenlog    String?  @db.VarChar(255)
  ip          String?  @db.VarChar(100)
  status      Int      @default(0)
  createtime  String?  @db.VarChar(100)
  coin        Int      @default(0)

  @@map("users")
}

model Post {
  id         BigInt    @id @default(autoincrement())
  slug       String    @db.VarChar(255)
  title      String    @db.Text
  sub_title  String?   @db.VarChar(255)
  content    String    @db.Text
  img_url    String    @db.VarChar(255)
  views      Int       @default(0)
  coin       Int?
  published  Int?
  server     Int?
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)

  @@map("posts")
}

model GiftCode {
  id    Int     @id @default(autoincrement())
  code  String  @db.VarChar(255)
  items String? @db.Text
  coin  Int     @default(0)
  gold  Int     @default(0)
  yen   Int     @default(0)

  @@map("gift_codes")
}

model Item {
  id   Int     @id @default(autoincrement())
  name String  @db.VarChar(255)
  icon String? @db.VarChar(500)

  @@map("item")
}
